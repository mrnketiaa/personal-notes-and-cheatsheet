## 12. Views

```sql
-- Create a view
CREATE VIEW active_employees AS
SELECT id, first_name, last_name, department, salary
FROM employees
WHERE is_active = TRUE;

-- Query a view
SELECT * FROM active_employees WHERE department = 'IT';

-- Replace/update view
CREATE OR REPLACE VIEW active_employees AS
SELECT id, first_name, last_name, email, department, salary
FROM employees
WHERE is_active = TRUE;

-- Create view with check option (prevents inserts/updates that don't match WHERE)
CREATE VIEW it_employees AS
SELECT * FROM employees WHERE department = 'IT'
WITH LOCAL CHECK OPTION;

-- Materialized view (stores query results physically)
CREATE MATERIALIZED VIEW dept_summary AS
SELECT department, COUNT(*) AS headcount, AVG(salary) AS avg_salary
FROM employees
GROUP BY department;

-- Refresh materialized view
REFRESH MATERIALIZED VIEW dept_summary;

-- Refresh without locking (allows reads during refresh)
REFRESH MATERIALIZED VIEW CONCURRENTLY dept_summary;

-- Create index on materialized view
CREATE INDEX idx_dept_summary ON dept_summary(department);

-- Drop view
DROP VIEW active_employees;
DROP MATERIALIZED VIEW dept_summary;

-- List all views
SELECT table_name FROM information_schema.views WHERE table_schema = 'public';
```

