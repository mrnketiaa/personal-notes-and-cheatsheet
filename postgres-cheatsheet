-- List all indexes
SELECT indexname, tablename, indexdef
FROM pg_indexes
WHERE schemaname = 'public';

-- Drop index
DROP INDEX idx_employees_department;
DROP INDEX CONCURRENTLY idx_employees_department;

-- Rebuild index
REINDEX INDEX idx_employees_department;
