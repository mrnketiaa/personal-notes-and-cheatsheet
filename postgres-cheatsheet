## 21. Performance & Query Analysis

```sql
-- EXPLAIN (shows query plan)
EXPLAIN SELECT * FROM employees WHERE department = 'IT';

-- EXPLAIN ANALYZE (runs the query and shows actual times)
EXPLAIN ANALYZE SELECT * FROM employees WHERE department = 'IT';

-- Full verbose output
EXPLAIN (ANALYZE, BUFFERS, VERBOSE, FORMAT TEXT)
SELECT * FROM employees WHERE salary > 70000;

-- Check slow queries (requires pg_stat_statements extension)
SELECT query, calls, total_exec_time, mean_exec_time
FROM pg_stat_statements
ORDER BY mean_exec_time DESC
LIMIT 10;

-- Table statistics
SELECT * FROM pg_stat_user_tables WHERE relname = 'employees';

-- Index usage stats
SELECT indexrelname, idx_scan, idx_tup_read, idx_tup_fetch
FROM pg_stat_user_indexes
WHERE relname = 'employees';

-- Unused indexes
SELECT relname, indexrelname, idx_scan
FROM pg_stat_user_indexes
WHERE idx_scan = 0;

-- Table bloat check
SELECT tablename, n_dead_tup, n_live_tup, last_vacuum, last_autovacuum
FROM pg_stat_user_tables
ORDER BY n_dead_tup DESC;

-- VACUUM (reclaim space from dead tuples)
VACUUM employees;
VACUUM VERBOSE ANALYZE employees;
VACUUM FULL employees;  -- Rewrites table (locks table)

-- ANALYZE (update table statistics)
ANALYZE employees;

-- Lock monitoring
SELECT pid, wait_event_type, wait_event, query
FROM pg_stat_activity
WHERE wait_event IS NOT NULL;

-- Kill long-running queries
SELECT pg_terminate_backend(pid)
FROM pg_stat_activity
WHERE state = 'active'
  AND now() - query_start > interval '5 minutes';

-- Connection count
SELECT count(*) FROM pg_stat_activity;

-- Cache hit ratio (aim for > 99%)
SELECT
    sum(heap_blks_hit) / (sum(heap_blks_hit) + sum(heap_blks_read)) AS cache_hit_ratio
FROM pg_statio_user_tables;

-- Set work_mem for current session (helps with sorts/hashes)
SET work_mem = '256MB';
```

