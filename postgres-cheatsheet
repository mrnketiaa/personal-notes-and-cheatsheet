## 15. Transactions

```sql
-- Basic transaction
BEGIN;
    UPDATE employees SET salary = salary + 5000 WHERE id = 1;
    UPDATE budgets SET amount = amount - 5000 WHERE department = 'IT';
COMMIT;

-- Rollback on error
BEGIN;
    DELETE FROM employees WHERE department = 'HR';
    -- Something went wrong:
ROLLBACK;

-- Savepoints (partial rollback)
BEGIN;
    INSERT INTO employees(first_name, last_name) VALUES ('A', 'B');
    SAVEPOINT sp1;

    INSERT INTO employees(first_name, last_name) VALUES ('C', 'D');
    SAVEPOINT sp2;

    -- Oops, rollback to sp1 only
    ROLLBACK TO SAVEPOINT sp1;

    -- Release savepoint
    RELEASE SAVEPOINT sp1;
COMMIT;

-- Transaction isolation levels
BEGIN TRANSACTION ISOLATION LEVEL READ COMMITTED;    -- Default
BEGIN TRANSACTION ISOLATION LEVEL REPEATABLE READ;
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;

-- Check current isolation level
SHOW transaction_isolation;

-- SET LOCAL (for current transaction only)
SET LOCAL lock_timeout = '5s';
```

