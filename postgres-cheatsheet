## 17. Sequences

```sql
-- Create sequence
CREATE SEQUENCE employee_id_seq
    START WITH 1000
    INCREMENT BY 1
    MINVALUE 1000
    MAXVALUE 9999999
    CACHE 10;

-- Use sequence
SELECT nextval('employee_id_seq');   -- Get next value
SELECT currval('employee_id_seq');   -- Current value (within session)
SELECT lastval();                    -- Last value returned by nextval

-- Set sequence value
SELECT setval('employee_id_seq', 5000);
SELECT setval('employee_id_seq', 5000, false);  -- Next call returns 5000

-- Alter sequence
ALTER SEQUENCE employee_id_seq INCREMENT BY 2;
ALTER SEQUENCE employee_id_seq RESTART WITH 1;

-- Use sequence as default
ALTER TABLE employees
ALTER COLUMN id SET DEFAULT nextval('employee_id_seq');

