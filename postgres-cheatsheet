## 13. Stored Procedures & Functions

```sql
-- Create a simple function
CREATE OR REPLACE FUNCTION get_full_name(p_id INTEGER)
RETURNS TEXT AS $$
DECLARE
    v_name TEXT;
BEGIN
    SELECT first_name || ' ' || last_name INTO v_name
    FROM employees WHERE id = p_id;
    RETURN v_name;
END;
$$ LANGUAGE plpgsql;

-- Call the function
SELECT get_full_name(1);

-- Function returning a table
CREATE OR REPLACE FUNCTION get_dept_employees(p_dept TEXT)
RETURNS TABLE(id INT, full_name TEXT, salary NUMERIC) AS $$
BEGIN
    RETURN QUERY
        SELECT e.id, e.first_name || ' ' || e.last_name, e.salary
        FROM employees e
        WHERE e.department = p_dept;
END;
$$ LANGUAGE plpgsql;

SELECT * FROM get_dept_employees('IT');

-- Function with OUT parameters
CREATE OR REPLACE FUNCTION get_salary_stats(
    OUT min_sal NUMERIC,
    OUT max_sal NUMERIC,
    OUT avg_sal NUMERIC
) AS $$
BEGIN
    SELECT MIN(salary), MAX(salary), AVG(salary)
    INTO min_sal, max_sal, avg_sal
    FROM employees;
END;
$$ LANGUAGE plpgsql;

SELECT * FROM get_salary_stats();

-- Procedure (no return value, supports transactions)
CREATE OR REPLACE PROCEDURE give_raise(p_dept TEXT, p_percent NUMERIC)
LANGUAGE plpgsql AS $$
BEGIN
    UPDATE employees
    SET salary = salary * (1 + p_percent / 100)
    WHERE department = p_dept;
    COMMIT;
END;
$$;

CALL give_raise('IT', 10);

-- Drop function / procedure
DROP FUNCTION get_full_name(INTEGER);
DROP PROCEDURE give_raise(TEXT, NUMERIC);

-- List functions
SELECT routine_name, routine_type
FROM information_schema.routines
WHERE routine_schema = 'public';

-- SQL language function (simpler)
CREATE OR REPLACE FUNCTION double_salary(p_salary NUMERIC)
RETURNS NUMERIC AS $$
    SELECT p_salary * 2;
$$ LANGUAGE sql;
```

