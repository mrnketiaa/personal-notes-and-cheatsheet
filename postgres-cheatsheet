## 23. JSON & JSONB

```sql
-- Create table with JSONB
CREATE TABLE products (
    id      SERIAL PRIMARY KEY,
    name    TEXT,
    data    JSONB
);

-- Insert JSON
INSERT INTO products (name, data) VALUES
('Phone', '{"brand": "Apple", "specs": {"ram": 8, "storage": 256}, "tags": ["mobile", "electronics"]}');

-- Access JSON fields
SELECT data -> 'brand' AS brand FROM products;             -- Returns JSON
SELECT data ->> 'brand' AS brand FROM products;            -- Returns TEXT
SELECT data -> 'specs' -> 'ram' AS ram FROM products;
SELECT data #> '{specs,ram}' AS ram FROM products;         -- Path operator
SELECT data #>> '{specs,ram}' AS ram FROM products;        -- Path as text

-- Query inside JSON
SELECT * FROM products WHERE data ->> 'brand' = 'Apple';
SELECT * FROM products WHERE (data -> 'specs' ->> 'ram')::INT > 4;

-- JSON array operations
SELECT data -> 'tags' -> 0 AS first_tag FROM products;       -- First element
SELECT * FROM products WHERE data -> 'tags' ? 'mobile';      -- Key exists
SELECT * FROM products WHERE data @> '{"brand": "Apple"}';   -- Contains

-- Update JSONB
UPDATE products
SET data = data || '{"color": "black"}'        -- Merge
WHERE id = 1;

UPDATE products
SET data = jsonb_set(data, '{specs,storage}', '512')
WHERE id = 1;

-- Delete JSON key
UPDATE products SET data = data - 'color' WHERE id = 1;

-- Expand JSON array to rows
SELECT id, jsonb_array_elements_text(data -> 'tags') AS tag FROM products;

-- Expand JSON object to key-value pairs
SELECT id, key, value FROM products, jsonb_each(data);

-- Aggregate to JSON
SELECT json_agg(row_to_json(employees)) FROM employees;
SELECT json_object_agg(id, first_name) FROM employees;

-- Build JSON objects
SELECT json_build_object('name', first_name, 'salary', salary) FROM employees;

-- GIN index for JSONB
CREATE INDEX idx_products_data ON products USING GIN (data);
CREATE INDEX idx_products_data_path ON products USING GIN (data jsonb_path_ops);
```

