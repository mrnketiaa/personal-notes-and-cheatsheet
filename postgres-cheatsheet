## 26. Inheritance

```sql
-- Parent table
CREATE TABLE vehicles (
    id      SERIAL PRIMARY KEY,
    make    TEXT,
    model   TEXT,
    year    INT
);

-- Child tables inherit all columns
CREATE TABLE cars (
    num_doors INT
) INHERITS (vehicles);

CREATE TABLE trucks (
    payload_tons NUMERIC
) INHERITS (vehicles);

-- Insert into child
INSERT INTO cars (make, model, year, num_doors) VALUES ('Toyota', 'Camry', 2023, 4);

-- Query parent (includes child rows)
SELECT * FROM vehicles;

-- Query only parent (exclude children)
SELECT * FROM ONLY vehicles;

-- Drop parent but keep children
DROP TABLE vehicles;  -- Will fail if children exist
DROP TABLE vehicles CASCADE;
