## 22. Window Functions

```sql
-- ROW_NUMBER: unique sequential number
SELECT first_name, salary,
    ROW_NUMBER() OVER (ORDER BY salary DESC) AS rank
FROM employees;

-- RANK: same rank for ties, gaps after tie
SELECT first_name, salary,
    RANK() OVER (ORDER BY salary DESC) AS rank
FROM employees;

-- DENSE_RANK: same rank for ties, no gaps
SELECT first_name, salary,
    DENSE_RANK() OVER (ORDER BY salary DESC) AS dense_rank
FROM employees;

-- NTILE: divide into N equal groups
SELECT first_name, salary,
    NTILE(4) OVER (ORDER BY salary) AS quartile
FROM employees;

-- LAG / LEAD (access other rows)
SELECT first_name, salary,
    LAG(salary) OVER (ORDER BY hired_at) AS prev_salary,
    LEAD(salary) OVER (ORDER BY hired_at) AS next_salary
FROM employees;

-- FIRST_VALUE / LAST_VALUE
SELECT first_name, department, salary,
    FIRST_VALUE(salary) OVER (PARTITION BY department ORDER BY salary DESC) AS top_salary
FROM employees;

-- Partition by department
SELECT first_name, department, salary,
    RANK() OVER (PARTITION BY department ORDER BY salary DESC) AS dept_rank
FROM employees;

-- Running total (cumulative sum)
SELECT first_name, salary,
    SUM(salary) OVER (ORDER BY hired_at ROWS UNBOUNDED PRECEDING) AS running_total
FROM employees;

-- Moving average (last 3 rows)
SELECT first_name, salary,
    AVG(salary) OVER (ORDER BY hired_at ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS moving_avg
FROM employees;

-- Percent rank (0 to 1)
SELECT first_name, salary,
    PERCENT_RANK() OVER (ORDER BY salary) AS pct_rank
FROM employees;
```

