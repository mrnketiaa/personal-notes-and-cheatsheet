## 6. CRUD Operations

### INSERT

```sql
-- Basic insert
INSERT INTO employees (first_name, last_name, email, salary)
VALUES ('John', 'Doe', 'john@example.com', 75000);

-- Insert multiple rows
INSERT INTO employees (first_name, last_name, salary) VALUES
    ('Jane', 'Smith', 82000),
    ('Bob', 'Johnson', 68000),
    ('Alice', 'Williams', 91000);

-- Insert and return generated ID
INSERT INTO employees (first_name, last_name)
VALUES ('Tom', 'Brown')
RETURNING id, created_at;

-- Insert from SELECT
INSERT INTO employees_backup
SELECT * FROM employees WHERE department = 'IT';

-- Upsert (Insert or Update on conflict)
INSERT INTO employees (id, first_name, last_name, email)
VALUES (1, 'John', 'Doe', 'john_new@example.com')
ON CONFLICT (id) DO UPDATE
    SET email = EXCLUDED.email,
        first_name = EXCLUDED.first_name;

-- Insert or do nothing on conflict
INSERT INTO employees (email, first_name, last_name)
VALUES ('john@example.com', 'John', 'Doe')
ON CONFLICT (email) DO NOTHING;
```

### SELECT

```sql
-- Basic select
SELECT * FROM employees;

-- Select specific columns
SELECT first_name, last_name, salary FROM employees;

-- Alias columns
SELECT first_name AS "First Name", salary * 12 AS annual_salary FROM employees;

-- Distinct values
SELECT DISTINCT department FROM employees;

-- Limit and offset
SELECT * FROM employees LIMIT 10;
SELECT * FROM employees LIMIT 10 OFFSET 20;  -- Page 3 (page size 10)

-- Conditional expressions
SELECT first_name,
    CASE
        WHEN salary < 50000 THEN 'Low'
        WHEN salary BETWEEN 50000 AND 80000 THEN 'Mid'
        ELSE 'High'
    END AS salary_band
FROM employees;

-- COALESCE (first non-null)
SELECT COALESCE(phone, email, 'No contact') AS contact FROM employees;

-- NULLIF (returns NULL if equal)
SELECT NULLIF(salary, 0) FROM employees;
```

### UPDATE

```sql
-- Basic update
UPDATE employees SET salary = 80000 WHERE id = 1;

-- Update multiple columns
UPDATE employees
SET salary = 85000, department = 'Engineering'
WHERE id = 1;

-- Update with calculation
UPDATE employees SET salary = salary * 1.10 WHERE department = 'Sales';

-- Update using another table
UPDATE employees e
SET department = d.name
FROM departments d
WHERE e.department_id = d.id;

-- Update and return updated rows
UPDATE employees SET is_active = FALSE
WHERE hired_at < '2010-01-01'
RETURNING id, first_name, last_name;
```

### DELETE

```sql
-- Basic delete
DELETE FROM employees WHERE id = 1;

-- Delete with condition
DELETE FROM employees WHERE is_active = FALSE AND hired_at < '2015-01-01';

-- Delete all rows (slower than TRUNCATE, but transactional)
DELETE FROM employees;

-- Delete using another table
DELETE FROM employees
WHERE department_id IN (SELECT id FROM departments WHERE closed = TRUE);

-- Delete and return deleted rows
DELETE FROM employees WHERE salary < 30000
RETURNING *;
```

