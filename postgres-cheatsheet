## 16. Constraints

```sql
-- PRIMARY KEY
ALTER TABLE employees ADD PRIMARY KEY (id);

-- FOREIGN KEY
ALTER TABLE employees
ADD CONSTRAINT fk_department
FOREIGN KEY (department_id) REFERENCES departments(id)
ON DELETE SET NULL
ON UPDATE CASCADE;

-- UNIQUE
ALTER TABLE employees ADD CONSTRAINT uq_email UNIQUE (email);

-- CHECK
ALTER TABLE employees
ADD CONSTRAINT chk_salary CHECK (salary >= 0);

ALTER TABLE employees
ADD CONSTRAINT chk_dates CHECK (end_date > start_date);

-- NOT NULL (via ALTER COLUMN)
ALTER TABLE employees ALTER COLUMN first_name SET NOT NULL;

-- Composite unique constraint
ALTER TABLE employee_projects
ADD CONSTRAINT uq_emp_proj UNIQUE (employee_id, project_id);

-- Deferred constraint (checked at COMMIT, not per row)
ALTER TABLE employees
ADD CONSTRAINT fk_manager
FOREIGN KEY (manager_id) REFERENCES employees(id)
DEFERRABLE INITIALLY DEFERRED;

-- List all constraints
SELECT conname, contype, conrelid::regclass
FROM pg_constraint
WHERE conrelid = 'employees'::regclass;

-- Drop constraint
ALTER TABLE employees DROP CONSTRAINT chk_salary;
```

