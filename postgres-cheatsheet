## 7. Filtering & Sorting

```sql
-- Basic WHERE
SELECT * FROM employees WHERE department = 'IT';

-- Comparison operators
WHERE salary > 50000
WHERE salary >= 50000
WHERE salary < 80000
WHERE salary <> 50000    -- Not equal
WHERE salary != 50000    -- Not equal (alternative)

-- Logical operators
WHERE department = 'IT' AND salary > 60000;
WHERE department = 'IT' OR department = 'HR';
WHERE NOT is_active;

-- BETWEEN (inclusive)
WHERE salary BETWEEN 50000 AND 80000;
WHERE hired_at BETWEEN '2020-01-01' AND '2022-12-31';

-- IN / NOT IN
WHERE department IN ('IT', 'HR', 'Finance');
WHERE id NOT IN (1, 2, 3);

-- LIKE / ILIKE (case-insensitive)
WHERE first_name LIKE 'J%';        -- Starts with J
WHERE email LIKE '%@gmail.com';    -- Ends with @gmail.com
WHERE last_name LIKE '_mith';      -- One char then 'mith'
WHERE first_name ILIKE 'john%';    -- Case-insensitive

-- IS NULL / IS NOT NULL
WHERE phone IS NULL;
WHERE email IS NOT NULL;

-- ORDER BY
SELECT * FROM employees ORDER BY salary DESC;
SELECT * FROM employees ORDER BY last_name ASC, first_name ASC;
SELECT * FROM employees ORDER BY hired_at DESC NULLS LAST;

-- FETCH (SQL standard LIMIT)
SELECT * FROM employees ORDER BY salary DESC FETCH FIRST 5 ROWS ONLY;
```

