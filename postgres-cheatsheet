CREATE INDEX idx_tags ON articles USING GIN (tags);

-- GiST index (for geometric, full-text)
CREATE INDEX idx_fts ON articles USING GIST (to_tsvector('english', body));

-- BRIN index (for large tables with sequential data)
CREATE INDEX idx_created_brin ON events USING BRIN (created_at);

-- Create index concurrently (no table lock)
