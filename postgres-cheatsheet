## 24. Full-Text Search

```sql
-- Create table with tsvector
CREATE TABLE articles (
    id      SERIAL PRIMARY KEY,
    title   TEXT,
    body    TEXT,
    tsv     TSVECTOR
);

-- Convert text to tsvector
SELECT to_tsvector('english', 'The quick brown fox jumps over the lazy dog');

-- Convert query to tsquery
SELECT to_tsquery('english', 'quick & fox');
SELECT plainto_tsquery('english', 'quick fox');      -- Handles plain text
SELECT websearch_to_tsquery('english', '"quick fox"'); -- Web-like syntax

-- Search
SELECT * FROM articles
WHERE to_tsvector('english', title || ' ' || body) @@ to_tsquery('english', 'fox & quick');

-- Rank results
SELECT title,
    ts_rank(to_tsvector('english', body), to_tsquery('english', 'database')) AS rank
FROM articles
WHERE to_tsvector('english', body) @@ to_tsquery('english', 'database')
ORDER BY rank DESC;

-- Highlight matches
SELECT ts_headline('english', body, to_tsquery('english', 'database'),
    'MaxFragments=2, MaxWords=10') AS snippet
FROM articles
WHERE to_tsvector('english', body) @@ to_tsquery('english', 'database');

-- Maintain tsvector with trigger
ALTER TABLE articles ADD COLUMN tsv TSVECTOR;

CREATE FUNCTION articles_tsv_trigger() RETURNS TRIGGER AS $$
BEGIN
    NEW.tsv := to_tsvector('english', NEW.title || ' ' || COALESCE(NEW.body, ''));
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER update_tsv BEFORE INSERT OR UPDATE ON articles
FOR EACH ROW EXECUTE FUNCTION articles_tsv_trigger();

-- Create GIN index on tsvector column
CREATE INDEX idx_articles_tsv ON articles USING GIN (tsv);

-- Search using indexed column
SELECT * FROM articles WHERE tsv @@ to_tsquery('english', 'database & performance');
```

